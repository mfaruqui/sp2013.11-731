    (best_logprob, translation) = max(final_stack)
    sys.stderr.write('best_marginalized: {0}\n'.format(translation))
    '''

    # find best translation by looking at the best scoring hypothesis
    # on the last stack
    winner = max(stacks[-1].itervalues(), key=lambda h: h.logprob)
    old_translation = extract_english_recursive(winner)
    sys.stderr.write('best_originalized: {0}\n\n'.format(old_translation))
   
    prev_logprob = winner.logprob - 1
    while winner.logprob > prev_logprob:
	prev_logprob = winner.logprob
	edits = modify_complete_hypothesis(winner)
	winner = max(edits, key=lambda h: h.logprob)

    translation = extract_english_recursive(winner)
    best_logprob = winner.logprob 

